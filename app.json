{
  "expo": {
    "name": "soccer-star-app",
    "slug": "soccer-star-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#10233A"
    },
    "scheme": "soccerstarapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#10233A"
      },
      "package": "com.soupsiz.soccerstarapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withAndroidCMakeStagingDir.js",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#10233A",
          "dark": {
            "backgroundColor": "#10233A"
          }
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "SoccerWidget",
              "label": "Soccer Star Widget",
              "minWidth": "160dp",
              "minHeight": "110dp",
              "description": "Widget Locket & Live Score",
              "previewImage": "./assets/icon.png",
              "updatePeriodMillis": 900000
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "25373c21-85d2-476a-b122-1681bdc94a1f"
      }
    }
  }
}
